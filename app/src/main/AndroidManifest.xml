<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Required by android.location.Geocoder for city name resolution -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- In-app update: detect connectivity to check for / download updates -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Exact alarms: API 31-32 (user may need to grant in battery settings) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"
        android:maxSdkVersion="32" />
    <!-- Exact alarms: API 33+ auto-granted for apps with core timing needs -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <!-- Re-schedule alarms after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Mushaf download keeps running in the background as a foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- In-app update: install the downloaded APK (user grants "install unknown apps" once) -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:name=".core.App"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:networkSecurityConfig="@xml/network_security_config"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:localeConfig="@xml/locales_config"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/Theme.Khatmah"
        tools:targetApi="33">

        <activity
            android:name=".core.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Khatmah.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- One-time onboarding wizard (self-contained NavHost). -->
        <activity android:name=".onboarding.OnboardingActivity" android:exported="false" />

        <!-- Single host for every Dest.screen() destination. Declared once; all host-model
             screens reuse it, so new screens never need a manifest entry. -->
        <activity android:name=".core.ScreenHostActivity" android:exported="false" />

        <!-- Reader activity -->
        <activity
            android:name=".feature.quran.ui.reader.ReaderActivity"
            android:exported="false" />

        <!-- Reader settings -->
        <activity
            android:name=".feature.quran.ui.settings.ReaderSettingsActivity"
            android:theme="@style/Theme.Khatmah.ReaderSettings"
            android:exported="false" />

        <!-- Reader search -->
        <activity
            android:name=".feature.quran.ui.search.ReaderSearchActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

        <receiver
            android:name=".widget.PrayerWidgetReceiver"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/prayer_widget_info" />
        </receiver>

        <!-- Receives exact-alarm broadcasts to trigger widget refresh at each prayer time -->
        <receiver
            android:name=".widget.PrayerAlarmReceiver"
            android:exported="false" />

        <!-- Receives exact-alarm broadcasts to post notifications -->
        <receiver
            android:name=".shared.reminders.ReminderReceiver"
            android:exported="false" />

        <!-- Re-schedules alarms after device reboot -->
        <receiver
            android:name=".shared.reminders.ReminderBootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Serves assets/adhan/*.mp3 as content:// URIs for notification channel sounds.
        Must be exported so the system notification service can read the audio files.
        Only serves static notification audio — no sensitive data is exposed. -->
        <provider
            android:name=".feature.prayer.notification.AdhanAssetProvider"
            android:authorities="${applicationId}.adhan_provider"
            android:exported="true"
            android:grantUriPermissions="true"
            tools:ignore="ExportedContentProvider" />

        <!-- QCF4 mushaf download — runs in the background, survives leaving the screen. -->
        <service
            android:name=".feature.quran.data.download.DownloadService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <!-- App-update APK download — runs in the background, survives the dialog closing. -->
        <service
            android:name=".feature.update.UpdateService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <!-- Serves the downloaded update APK (cacheDir/updates) to the system installer. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- FCM token refresh service -->
        <service
            android:name=".shared.fcm.KhatmahFcmService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>

</manifest>