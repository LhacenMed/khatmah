<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/today">

    <!--
        Top-level destinations: IDs match bottom_nav_menu item IDs exactly so
        NavigationUI can sync bottom nav selection state automatically.
    -->

    <fragment
        android:id="@+id/today"
        android:name="com.lhacenmed.khatmah.ui.page.today.TodayFragment"
        android:label="@string/today">
        <action
            android:id="@+id/action_today_to_themeSettings"
            app:destination="@id/themeSettings"/>
        <action
            android:id="@+id/action_today_to_language"
            app:destination="@id/language"/>
    </fragment>

    <fragment
        android:id="@+id/athkar"
        android:name="com.lhacenmed.khatmah.ui.page.athkar.AthkarFragment"
        android:label="@string/athkar"/>

    <fragment
        android:id="@+id/prayers"
        android:name="com.lhacenmed.khatmah.ui.page.prayers.PrayersFragment"
        android:label="@string/prayers"/>

    <fragment
        android:id="@+id/index"
        android:name="com.lhacenmed.khatmah.ui.page.index.IndexFragment"
        android:label="@string/index"/>

    <fragment
        android:id="@+id/more"
        android:name="com.lhacenmed.khatmah.ui.page.more.MoreFragment"
        android:label="@string/more"/>

    <!--
        Sub-pages: NOT in AppBarConfiguration's top-level set →
        NavigationUI auto-shows the back arrow in the toolbar.
    -->

    <fragment
        android:id="@+id/themeSettings"
        android:name="com.lhacenmed.khatmah.ui.page.settings.appearance.ThemeSettingsFragment"
        android:label="@string/theme_settings"/>

    <fragment
        android:id="@+id/language"
        android:name="com.lhacenmed.khatmah.ui.page.settings.appearance.LanguageFragment"
        android:label="@string/language_settings"/>

</navigation>