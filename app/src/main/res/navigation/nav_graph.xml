<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/today">

    <!--
        Top-level destinations match bottom_nav_menu item IDs exactly.
        NavigationUI uses this match to sync bottom nav selection state.
    -->

    <fragment
        android:id="@+id/today"
        android:name="com.lhacenmed.khatmah.TodayFragment"
        android:label="@string/today">
        <action
            android:id="@+id/action_today_to_themeSettings"
            app:destination="@id/themeSettings"/>
    </fragment>

    <fragment
        android:id="@+id/athkar"
        android:name="com.lhacenmed.khatmah.AthkarFragment"
        android:label="@string/athkar"/>

    <fragment
        android:id="@+id/prayers"
        android:name="com.lhacenmed.khatmah.PrayersFragment"
        android:label="@string/prayers"/>

    <fragment
        android:id="@+id/index"
        android:name="com.lhacenmed.khatmah.IndexFragment"
        android:label="@string/index"/>

    <fragment
        android:id="@+id/more"
        android:name="com.lhacenmed.khatmah.MoreFragment"
        android:label="@string/more"/>

    <!--
        themeSettings is NOT in AppBarConfiguration's top-level set →
        NavigationUI automatically shows the back arrow in the toolbar.
    -->
    <fragment
        android:id="@+id/themeSettings"
        android:name="com.lhacenmed.khatmah.ThemeSettingsFragment"
        android:label="@string/theme_settings"/>

</navigation>