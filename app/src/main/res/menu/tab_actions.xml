<?xml version="1.0" encoding="utf-8"?>
<!-- Toolbar actions; visibility is toggled per selected tab (and Adhkar selection mode) in MainActivity. -->
<menu xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Adhkar — normal -->
    <item
        android:id="@+id/action_adhkar_add"
        android:icon="@drawable/ic_add"
        android:title="@string/add_adhkar"
        app:showAsAction="always" />

    <!-- Adhkar — selection mode -->
    <item
        android:id="@+id/action_adhkar_select_all"
        android:icon="@drawable/ic_done_all"
        android:title="@string/select_all"
        app:showAsAction="always" />
    <item
        android:id="@+id/action_adhkar_delete"
        android:title="@string/delete"
        app:showAsAction="always|withText" />

    <!-- Prayers -->
    <item
        android:id="@+id/action_qibla"
        android:icon="@drawable/ic_kaaba"
        android:title="@string/prayers_qibla"
        app:showAsAction="always" />
    <item
        android:id="@+id/action_prayer_settings"
        android:icon="@drawable/ic_settings"
        android:title="@string/prayers_settings"
        app:showAsAction="always" />

    <!-- Qadaa -->
    <item
        android:id="@+id/action_qadaa_history"
        android:icon="@drawable/ic_history"
        android:title="@string/qadaa_history"
        app:showAsAction="always" />
    <item
        android:id="@+id/action_qadaa_add"
        android:icon="@drawable/ic_add"
        android:title="@string/qadaa_add_prayers_title"
        app:showAsAction="always" />
</menu>
