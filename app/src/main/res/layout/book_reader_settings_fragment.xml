<?xml version="1.0" encoding="utf-8"?>
<!-- Native reader settings — two categories matching Quran Android's display + reading
     preferences: night mode, text/background brightness, and the page-info overlay.
     Horizontal padding lives on each item (not the container) so clickable rows span the
     full width and their ripple fills the whole row. -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="12dp">

        <!-- ── Display settings ─────────────────────────────────────────────── -->

        <TextView
            style="?attr/textAppearanceTitleSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp"
            android:text="إعدادات العرض"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold" />

        <!-- Night mode -->
        <LinearLayout
            android:id="@+id/row_night"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="الوضع الليلي"
                android:textAppearance="?attr/textAppearanceBodyLarge" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/check_night"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false"
                android:focusable="false" />
        </LinearLayout>

        <!-- Brightness + preview — disabled (dimmed) when night mode is off. -->
        <LinearLayout
            android:id="@+id/brightness_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Brightness preview (always shows the night look being adjusted) -->
            <FrameLayout
                android:id="@+id/preview"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/preview_text"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ"
                android:textSize="20sp" />
        </FrameLayout>

        <!-- Text brightness -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingTop="8dp"
            android:text="سطوع النص"
            android:textAppearance="?attr/textAppearanceBodyLarge" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp">

            <SeekBar
                android:id="@+id/seek_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="255" />

            <TextView
                android:id="@+id/val_text"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textAppearance="?attr/textAppearanceBodyMedium" />
        </LinearLayout>

        <!-- Background brightness -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingTop="8dp"
            android:text="سطوع الخلفية"
            android:textAppearance="?attr/textAppearanceBodyLarge" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp">

            <SeekBar
                android:id="@+id/seek_bg"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="64" />

            <TextView
                android:id="@+id/val_bg"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textAppearance="?attr/textAppearanceBodyMedium" />
        </LinearLayout>
        </LinearLayout>

        <!-- ── Reading preferences ──────────────────────────────────────────── -->

        <TextView
            style="?attr/textAppearanceTitleSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp"
            android:text="تفضيلات القراءة"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold" />

        <!-- Show page info -->
        <LinearLayout
            android:id="@+id/row_page_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingVertical="6dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="عرض معلومات الصفحة"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="رقم الصفحة واسم السورة ورقم الجزء أثناء القراءة"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?android:attr/textColorSecondary" />
            </LinearLayout>

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/check_page_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false"
                android:focusable="false" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
