<?xml version="1.0" encoding="utf-8"?>
<!--
  Host for Dest.screen() pages. The MaterialToolbar (shown only when the Dest sets a title)
  gives every detail screen the same native chrome as the tabs, with a platform back arrow
  that mirrors automatically in RTL. The body is Compose. Status-bar inset is applied in code.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Fixed actionBarSize height so the title and back arrow share one clean bar (the
         status-bar inset is applied to the root in code, not to the toolbar). -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorSurface" />

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/compose_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
