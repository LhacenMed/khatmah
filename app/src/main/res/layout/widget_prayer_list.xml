            android:textSize="19sp"
            android:textColor="#FFFFFF"
            android:maxLines="1"
            android:ellipsize="end"/>
    </RelativeLayout>

    <!-- Row 3 ─────────────────────────────────────────────────────────────── -->
    <RelativeLayout
        android:id="@+id/prayer_row_3"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
