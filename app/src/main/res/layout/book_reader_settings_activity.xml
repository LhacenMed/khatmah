<?xml version="1.0" encoding="utf-8"?>
<!-- Reader settings shell — native toolbar + fragment container. -->
<!-- Edge-to-edge: the toolbar covers the status-bar strip (surfaceContainer) and the body
     extends under the nav bar with the page background (surface), so both system-bar strips
     match the regions they sit over. Insets are applied in the activity. -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:elevation="4dp"
        app:titleTextAppearance="@style/ToolbarTitleText"
        app:subtitleTextAppearance="@style/ToolbarSubtitleText" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/settings_container"
        android:name="com.lhacenmed.khatmah.feature.quran.ui.settings.ReaderSettingsFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface" />
</LinearLayout>
