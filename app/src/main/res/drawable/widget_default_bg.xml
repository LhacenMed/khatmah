<?xml version="1.0" encoding="utf-8"?>
<!--
    Rounded surface for the static initial/preview layout. The solid color is a Material 3
    theme attribute, so it resolves to the dynamic palette when the host layout is themed
    with Theme.Khatmah.Widget — mirroring the Glance shell's secondaryContainer background.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="?attr/colorSecondaryContainer" />
    <corners android:radius="15dp" />
</shape>
